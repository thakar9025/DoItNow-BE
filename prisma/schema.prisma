generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(uuid()) @db.Uuid

  email String? @unique
  phone String? @unique

  fullName  String?
  avatarUrl String?

  role     user_role @default(USER)
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fcmToken  String?

  authProviders          AuthProvider[]
  sessions               UserSession[]
  addresses              Address[]
  bookings               Booking[]
  notifications          Notification[]
  deviceTokens           UserDeviceToken[]
  notificationPreference UserNotificationPreference?
}

enum user_role {
  USER
  ADMIN
  SUPER_ADMIN
}

model AuthProvider {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  provider       String
  providerUserId String

  providerEmail     String?
  providerAvatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RevokedToken {
  id        String   @id @default(uuid()) @db.Uuid
  jti       String   @unique
  userId    String   @db.Uuid
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Service {
  id          String  @id
  slug        String  @unique
  title       String
  subtitle    String?
  description String?

  startingPrice Int
  currency      String

  imageUrl    String?
  iconUrl     String?
  displayType DisplayType @default(ICON)
  colorClass  String?

  tag       String?
  isPopular Boolean   @default(false)
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings        Booking[]
  partnerServices PartnerService[]
  addonGroups     ServiceAddonGroup[]

  @@index([isActive])
}

enum AddonSelectionType {
  SINGLE
  MULTI
}

model ServiceAddonGroup {
  id            String             @id @default(uuid()) @db.Uuid
  serviceId     String             @map("service_id")
  title         String
  helpText      String?            @map("help_text")
  selectionType AddonSelectionType @default(MULTI) @map("selection_type")
  minSelection  Int                @default(0) @map("min_selection")
  maxSelection  Int?               @map("max_selection")
  isRequired    Boolean            @default(false) @map("is_required")
  sortOrder     Int                @default(0) @map("sort_order")
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  service Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  addons  ServiceAddon[]

  @@index([serviceId, isActive, sortOrder])
  @@map("service_addon_groups")
}

model ServiceAddon {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  label       String
  description String?
  price       Int
  currency    String   @default("INR")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group         ServiceAddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  bookingAddons BookingAddon[]

  @@index([groupId, isActive, sortOrder])
  @@map("service_addons")
}

enum DisplayType {
  IMAGE
  ICON
}

model Address {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  // display
  label       String
  // Denormalized string kept in DB (legacy/non-null constraint in some environments).
  fullAddress String

  // geo (VERY IMPORTANT)
  latitude  Float?
  longitude Float?

  // structured address (from Google)
  area    String?
  city    String?
  state   String?
  pincode String?

  // user input (MOST IMPORTANT)
  houseNumber String?
  building    String?
  landmark    String?

  // metadata
  addressType String? // HOME / WORK / OTHER
  contactName String?
  phone       String?

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([userId])
}

model Booking {
  id String @id @default(uuid()) @db.Uuid

  userId    String @db.Uuid
  serviceId String
  addressId String @db.Uuid

  date     DateTime @db.Date
  timeSlot String
  phone    String

  price Int
  notes String?
  customerRating Float? @map("customer_rating")

  status BookingStatus @default(PENDING)

  partnerName     String?
  partnerPhone    String?
  rejectionReason String?
  partnerId       String?  @db.Uuid
  partner         Partner? @relation(fields: [partnerId], references: [id])

  confirmedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])
  address Address @relation(fields: [addressId], references: [id])
  addons  BookingAddon[]

  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([serviceId])
  @@index([addressId])
  @@index([status, date])
}

model BookingAddon {
  id        String  @id @default(uuid()) @db.Uuid
  bookingId String  @map("booking_id") @db.Uuid
  addonId   String? @map("addon_id") @db.Uuid
  label     String
  price     Int

  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addon   ServiceAddon? @relation(fields: [addonId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@map("booking_addons")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  CANCELLED_BY_ADMIN
  CANCELLED_BY_USER
}

model Partner {
  id        String           @id @default(uuid()) @db.Uuid
  fullName  String
  phone     String
  email     String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  bookings  Booking[] // relation (optional but recommended)
  services  PartnerService[]
  addresses PartnerAddress[]
}

model PartnerService {
  id        String   @id @default(uuid()) @db.Uuid
  partnerId String   @db.Uuid
  serviceId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([partnerId, serviceId])
  @@index([serviceId, isActive])
  @@index([partnerId, isActive])
}

model PartnerAddress {
  id          String   @id @default(uuid()) @db.Uuid
  partnerId   String   @db.Uuid
  label       String
  fullAddress String
  latitude    Float?
  longitude   Float?
  area        String?
  city        String?
  state       String?
  pincode     String?
  houseNumber String?
  building    String?
  landmark    String?
  addressType String?
  contactName String?
  phone       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([partnerId, isDefault])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String
  payload   Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, createdAt])
  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model NotificationOutbox {
  id            String                  @id @default(uuid()) @db.Uuid
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        NotificationQueueStatus @default(PENDING)
  attempts      Int                     @default(0)
  nextAttemptAt DateTime?
  lastError     String?
  processedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  deliveries NotificationDelivery[]

  @@index([status, nextAttemptAt, createdAt])
  @@index([aggregateType, aggregateId, createdAt])
  @@map("notification_outbox")
}

model NotificationDelivery {
  id                String                     @id @default(uuid()) @db.Uuid
  notificationId    String?                    @db.Uuid
  outboxId          String?                    @db.Uuid
  channel           NotificationChannel
  recipient         String
  providerMessageId String?
  status            NotificationDeliveryStatus @default(PENDING)
  attempts          Int                        @default(0)
  error             String?
  sentAt            DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  notification Notification?       @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  outbox       NotificationOutbox? @relation(fields: [outboxId], references: [id], onDelete: SetNull)

  @@index([notificationId, channel, createdAt])
  @@index([outboxId, channel, createdAt])
  @@index([status, createdAt])
  @@map("notification_deliveries")
}

model UserDeviceToken {
  id         String         @id @default(uuid()) @db.Uuid
  userId     String         @db.Uuid
  token      String         @unique
  platform   DevicePlatform
  isActive   Boolean        @default(true)
  lastSeenAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive, updatedAt])
  @@map("user_device_tokens")
}

model UserNotificationPreference {
  userId                String   @id @db.Uuid
  bookingPushEnabled    Boolean  @default(true)
  bookingEmailEnabled   Boolean  @default(true)
  marketingPushEnabled  Boolean  @default(false)
  marketingEmailEnabled Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_APPROVED
  BOOKING_REJECTED_BY_ADMIN
  BOOKING_CANCELLED_BY_USER
  BOOKING_COMPLETED
  BOOKING_STATUS_CHANGED
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

enum NotificationQueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum NotificationDeliveryStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  UNKNOWN
}

model SupportFaq {
  id        String   @id @default(uuid()) @db.Uuid
  question  String
  answer    String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("support_faqs")
}

model SupportSetting {
  id           String   @id @default("default")
  supportEmail String   @map("support_email")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("support_settings")
}

enum EmailQueueStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model EmailQueue {
  id             String           @id @default(uuid()) @db.Uuid
  idempotencyKey String?          @unique @map("idempotency_key")
  toEmail        String           @map("to_email")
  subject        String
  textBody       String           @map("text_body")
  htmlBody       String           @map("html_body")
  status         EmailQueueStatus @default(PENDING)
  attempts       Int              @default(0)
  maxAttempts    Int              @default(5) @map("max_attempts")
  scheduledAt    DateTime         @default(now()) @map("scheduled_at")
  lockedAt       DateTime?        @map("locked_at")
  sentAt         DateTime?        @map("sent_at")
  lastError      String?          @map("last_error")
  metadata       Json?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@index([status, scheduledAt, createdAt])
  @@map("email_queue")
}
