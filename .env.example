# .env file

# Application
PORT=3000
NODE_ENV=development

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://<user>:<password>@<host>:6543/<db>?pgbouncer=true&sslmode=require"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require"

# Prefer DIRECT_URL in development (set to false to use DATABASE_URL / pooler instead)
DB_PREFER_DIRECT_URL=false

# JWT
JWT_SECRET=replace-with-a-32-char-min-secret-value
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
JWT_ISSUER=homehelp-api
JWT_AUDIENCE=homehelp-client

# Google OAuth - User App
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id

# Google OAuth - Admin App (separate Google project/client)
GOOGLE_ADMIN_CLIENT_ID=your-google-admin-client-id
GOOGLE_ADMIN_WEB_CLIENT_ID=your-google-admin-web-client-id
GOOGLE_ADMIN_ANDROID_CLIENT_ID=your-google-admin-android-client-id

# Supabase Storage (Catalog image/icon public URL generation)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_STORAGE_BUCKET=imgs
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Firebase configs
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"


